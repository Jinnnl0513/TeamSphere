# Fix #15: Enforce LF line endings for all text files in this repository.
# This prevents mixed CRLF/LF across SQL migration files and Go source files.

# Default: auto-detect and normalize to LF
* text=auto eol=lf

# Go source files
*.go text eol=lf

# SQL migration files
*.sql text eol=lf

# TypeScript/JavaScript frontend
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
*.sh text eol=lf

# Binary files — don't touch
*.png binary
*.jpg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
